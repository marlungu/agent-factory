# The factory writes results here when run.
# Keep the folder in Git but ignore everything generated inside it.
example/job-application-factory/output/*
!example/job-application-factory/output/.gitkeep

# Claude Code local/personal settings (never commit machine-specific config)
**/.claude/settings.local.json

# OS noise
.DS_Store

# Ignore personal input files; keep only the shipped samples
example/job-application-factory/input/*
!example/job-application-factory/input/job_description.txt
!example/job-application-factory/input/resume.txt